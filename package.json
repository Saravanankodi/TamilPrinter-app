{
  "name": "printout",
  "version": "0.1.3",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"npm:electron\"",
    "electron": "wait-on http://localhost:3000 && electron .",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:next": "next build",
    "build": "npm run build:next && node scripts/copy-static.js && npm run build:electron",
    "dist": "npm run build && electron-builder",
    "start": "next start",
    "lint": "eslint"
  },
  "build": {
    "appId": "com.printout.app",
    "productName": "TamilPrinter",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      ".next/standalone/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "html2canvas-pro": "^2.0.2",
    "jspdf": "^4.2.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sweetalert2": "^11.26.23"
  },
  "devDependencies": {
    "@svgr/cli": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
